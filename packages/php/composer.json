{
    "name": "palpluss/sdk",
    "description": "Official PHP SDK for the PalPluss API",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "PalPluss\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PalPluss\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "optimize-autoloader": true
    }
}
