{
  "name": "@palpluss/sdk",
  "version": "0.1.0",
  "description": "Official PalPluss TypeScript SDK",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/palpluss/palpluss-sdk.git",
    "directory": "packages/typescript"
  },
  "homepage": "https://github.com/palpluss/palpluss-sdk/tree/main/packages/typescript#readme",
  "keywords": [
    "palpluss",
    "payments",
    "mpesa",
    "stk-push",
    "b2c",
    "sdk"
  ],
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "release": "pnpm build && changeset publish"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@eslint/js": "^9.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "jest": "^29.5.0",
    "jest-fetch-mock": "^3.0.3",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
